# Copia este archivo a .env.local y rellena los valores.
# En Vercel: Settings → Environment Variables (no subas .env al repo).

# Firebase Admin (server: Firestore, Auth, session cookies)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase REST / custom token (server actions: login email, registro)
FIREBASE_API_KEY=

# Firebase Client (login con Google en el navegador)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
