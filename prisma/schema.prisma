// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  passwordHash   String
  role           String        @default("CUSTOMER") // SUPERADMIN, CUSTOMER
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  RawMaterials   RawMaterial[]
  Formulas       Formula[]
  WorkOrders     WorkOrder[]
}

model RawMaterial {
  id                   String              @id @default(uuid())
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId               String
  name                 String
  stockKg              Float
  concentrationPercent Float
  densityKgL           Float
  pricePerKg           Float
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  FormulaIngredients   FormulaIngredient[]
}

model Formula {
  id                 String              @id @default(uuid())
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  name               String
  version            Int                 @default(1)
  instructions       String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  FormulaIngredients FormulaIngredient[]
  WorkOrders         WorkOrder[]
}

model FormulaIngredient {
  id            String      @id @default(uuid())
  formula       Formula     @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  formulaId     String
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  rawMaterialId String
  quantityKg    Float
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model WorkOrder {
  id                 String    @id @default(uuid())
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  formula            Formula   @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  formulaId          String
  targetVolumeLiters Float
  status             String    @default("PENDING")
  createdAt          DateTime  @default(now())
  completedAt        DateTime?
  observations       String?
  updatedAt          DateTime  @updatedAt
}
